{
    "name": "richardwooding/arcgis",
    "description": "A small, dependency-free PHP client for querying ArcGIS Feature Services over their REST API.",
    "type": "library",
    "license": "MIT",
    "keywords": ["arcgis", "esri", "gis", "feature-service", "geojson", "rest"],
    "authors": [
        {
            "name": "Richard Wooding"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.64"
    },
    "autoload": {
        "psr-4": {
            "RichardWooding\\ArcGis\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RichardWooding\\ArcGis\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --memory-limit=512M",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "fix": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true
    }
}
